<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<!-- Asset-catalog-managed AppIcon so the icon theme-snaps (light/dark)
	     like first-party Tahoe apps. -->
	<key>CFBundleIconName</key>
	<string>AppIcon</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>suzu</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.utilities</string>
	<key>LSMinimumSystemVersion</key>
	<string>26.0</string>
	<!-- Menu-bar-only accessory: no Dock icon, no main window on launch. -->
	<key>LSUIElement</key>
	<true/>
	<key>NSHumanReadableCopyright</key>
	<string>Copyright © 2026 ugfugl.io. All rights reserved.</string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<!-- Sparkle auto-update (sandboxed, Developer ID + notarized). SUFeedURL is
	     the public appcast served from the repo's GitHub Pages site. SUPublicEDKey
	     is the ed25519 PUBLIC key; the private half lives in the signing creds
	     file (~/.config/suzu/signing.env) and is used by `make release-publish`.
	     A sandboxed app installs updates through Sparkle's Installer Launcher XPC
	     service (SUEnableInstallerLauncherService); the matching mach-lookup
	     exception + network.client live in Suzu.entitlements. Background checks
	     run daily; the user is always asked before an update installs. -->
	<key>SUFeedURL</key>
	<string>https://se7enbrc.github.io/suzu/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>4P3q7toz/gW/C1MJ2PJg/SAJXHXLfgxLWVei1G2KdVA=</string>
	<key>SUEnableInstallerLauncherService</key>
	<true/>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<key>SUScheduledCheckInterval</key>
	<integer>86400</integer>
</dict>
</plist>
